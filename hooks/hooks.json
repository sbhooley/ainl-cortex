{
  "description": "AINL-inspired graph memory system for Claude Code - execution becomes memory",
  "hooks": {
    "SessionStart": [{
      "hooks": [{
        "type": "command",
        "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:$PYTHONPATH\" .venv/bin/python hooks/startup.py",
        "timeout": 20
      }]
    }],
    "UserPromptSubmit": [{
      "hooks": [{
        "type": "command",
        "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:$PYTHONPATH\" .venv/bin/python hooks/user_prompt_submit.py",
        "timeout": 5
      }, {
        "type": "command",
        "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:$PYTHONPATH\" .venv/bin/python hooks/ainl_detection.py",
        "timeout": 3
      }]
    }],
    "UserPromptExpansion": [{
      "hooks": [{
        "type": "command",
        "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:$PYTHONPATH\" .venv/bin/python hooks/user_prompt_expansion.py",
        "timeout": 3
      }]
    }],
    "PostToolUse": [{
      "hooks": [{
        "type": "command",
        "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:$PYTHONPATH\" .venv/bin/python hooks/post_tool_use.py",
        "timeout": 3
      }]
    }],
    "PreCompact": [{
      "hooks": [{
        "type": "command",
        "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:$PYTHONPATH\" .venv/bin/python hooks/pre_compact.py",
        "timeout": 3
      }]
    }],
    "PostCompact": [{
      "hooks": [{
        "type": "command",
        "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:$PYTHONPATH\" .venv/bin/python hooks/post_compact.py",
        "timeout": 3
      }]
    }],
    "Stop": [{
      "hooks": [{
        "type": "command",
        "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:$PYTHONPATH\" .venv/bin/python hooks/stop.py",
        "timeout": 5
      }]
    }]
  }
}
