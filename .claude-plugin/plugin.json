{
  "name": "ainl-graph-memory",
  "displayName": "AINL Graph Memory",
  "version": "0.2.0",
  "description": "Graph-native memory and self-learning for Claude Code. Every session is captured, indexed, and recalled — your assistant gets smarter over time.",
  "author": { "name": "Steven Hooley" },
  "repository": "https://github.com/sbhooley/ainativelang-claudecode",
  "keywords": ["memory", "graph", "ainl", "persistence", "agent", "coding-assistant"],
  "license": "MIT OR Apache-2.0",
  "compatibility": {
    "minClaudeCodeVersion": "0.1.0"
  },
  "readme": "README.md",
  "mcpServers": {
    "ainl-graph-memory": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp_launch.sh"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    }
  }
}
