{
  "cost_profile": "balanced",
  "conversation": {
    "enabled": true,
    "suppress_mcp_hint": true
  },
  "notifications": {
    "enabled": true,
    "url": "https://www.ainativelang.com/notifications",
    "check_timeout_seconds": 5,
    "auto_update": false
  },
  "features": {
    "graph_memory": true,
    "context_injection": true,
    "trajectory_capture": true,
    "session_hooks": true,
    "pattern_learning": true,
    "failure_learning": true,
    "persona_evolution": true,
    "semantic_facts": true,
    "user_prompt_compression": true,
    "memory_context_compression": true
  },
  "knowledge_capture": {
    "artifact_ingestion": {
      "enabled": true,
      "suffixes": [".md", ".txt", ".mdx"],
      "plan_name_substrings": ["game_plan", "game-plan", "plan", "research", "mastery"],
      "min_chars": 200,
      "max_file_bytes": 512000,
      "max_facts_per_artifact": 40,
      "max_fact_chars": 400,
      "min_confidence": 0.55
    },
    "research_capture": {
      "enabled": true,
      "web_digest_threshold_chars": 800,
      "max_facts_per_session": 25,
      "default_tags": ["research", "knowledge"]
    },
    "session_synthesis": {
      "enabled": true,
      "min_facts": 5,
      "max_facts": 15,
      "trigger_tools": ["web_search", "web_fetch", "write", "edit"]
    },
    "extraction": {
      "llm": {
        "enabled": false,
        "provider": "openrouter",
        "model": "anthropic/claude-3.5-haiku",
        "api_key_env": "OPENROUTER_API_KEY",
        "max_input_chars": 24000,
        "timeout_s": 25,
        "max_facts": 20
      }
    },
    "recall": {
      "topical_intent": true,
      "extra_terms": ["clipping", "craigcast", "virality", "linkedin", "game_plan"],
      "topical_fts_limit": 8
    },
    "claude_memory_bridge": {
      "enabled": false,
      "memory_dir_name": "memory",
      "file_prefix": "reference_",
      "max_facts_per_file": 30
    },
    "stop_time_budget_ms": 2500,
    "prompt_remember": {
      "enabled": true,
      "min_user_body_chars": 120,
      "max_assistant_chars": 12000,
      "max_facts": 25,
      "time_budget_s": 2.0,
      "include_research_capture": true
    }
  },
  "memory": {
    "max_context_tokens": 800,
    "project_isolation": true,
    "project_isolation_mode": "per_repo",
    "enable_persona_evolution": true,
    "enable_pattern_extraction": true,
    "store_backend": "python",
    "recall_detail_level": "standard",
    "recall_min_prompt_chars": 60,
    "recall_compile_max_nodes": 20,
    "repartition_max_depth": 3,
    "semantic_lexical_fallback": false,
    "confidence_decay_days": 90,
    "confidence_decay_factor": 0.05,
    "node_ttl_days": 365
  },
  "telemetry": {
    "track_compression_savings": true,
    "log_compression_details": false,
    "track_quality_scores": true,
    "track_adaptive_decisions": true,
    "remote": {
      "enabled": true
    }
  },
  "a2a": {
    "enabled": true,
    "daemon_json": "~/.armaraos/daemon.json",
    "bridge_port": 7860,
    "bridge_host": "127.0.0.1",
    "bridge_pidfile": "a2a/bridge.pid",
    "bridge_logfile": "a2a/logs/bridge.log",
    "inbox_max_messages": 50,
    "inbox_max_age_seconds": 86400,
    "inbox_max_message_chars": 2000,
    "self_inbox_urgency": "critical",
    "self_note_threshold": 5,
    "mid_session_flush_threshold": 5,
    "thread_recall_n": 5,
    "monitor_script": "agents/context_monitor.py"
  },
  "retrieval": {
    "similarity_enabled": true,
    "similarity_backend": "auto",
    "retrieval_mode": "tfidf",
    "tfidf_cache_ttl_seconds": 300,
    "min_similarity_score": 0.15,
    "candidate_pool_size": 100
  },
  "failure_advisor": {
    "enabled": true,
    "min_confidence": 0.3,
    "max_warnings": 3,
    "warn_on_files": true,
    "warn_on_commands": true
  },
  "autonomous_mode": {
    "enabled": true,
    "allow_self_scheduling": true,
    "inject_due_tasks_in_startup": true,
    "due_tasks_lookahead_minutes": 60,
    "approved_autonomous_actions": [
      "memory_list_goals",
      "memory_recall_context",
      "memory_search",
      "memory_store_episode",
      "memory_store_semantic",
      "memory_list_scheduled_tasks"
    ]
  },
  "goals": {
    "enabled": true,
    "auto_infer": true,
    "min_episodes_for_inference": 3,
    "max_active_goals": 10,
    "inject_in_context": true,
    "link_threshold": 0.15
  },
  "compression": {
    "enabled": true,
    "mode": "balanced",
    "compress_memory_context": true,
    "compress_user_prompt": true,
    "compress_output": false,
    "min_tokens_for_compression": 50,
    "adaptive_eco": {
      "enabled": true,
      "min_confidence": 0.7,
      "hysteresis_count": 2
    },
    "semantic_scoring": {
      "enabled": true,
      "min_overall_score": 0.7,
      "min_key_term_retention": 0.8,
      "track_quality": true
    },
    "project_profiles": {
      "enabled": true,
      "auto_detect_mode": true,
      "min_compressions_for_detection": 5
    },
    "cache_awareness": {
      "enabled": true,
      "prefer_cache_hits": true,
      "cache_ttl": 300,
      "hysteresis_duration": 120,
      "preserve_warm_cache": true
    },
    "output": {
      "enabled": false,
      "mode": "balanced",
      "min_length_tokens": 200,
      "show_badge": false
    }
  }
}
